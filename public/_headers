# Cloudflare Pages headers
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://maps.googleapis.com https://maps.gstatic.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; media-src 'self' https://res.cloudinary.com https://videos.pexels.com; connect-src 'self' https://webhooks.autosocialflow.com.br https://cloudflareinsights.com https://static.cloudflareinsights.com; frame-src https://maps.google.com https://www.google.com https://*.google.com https://*.google.com.br; frame-ancestors 'none';
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin

# Assets com hash gerados pelo Astro — cache imutável de 1 ano
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Imagens e vídeos estáticos — cache de 30 dias
/images/*
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.mp4
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000

# Arquivos de rastreamento — cache curto para atualizações rápidas
/robots.txt
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-0.xml
  Cache-Control: public, max-age=3600
